<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pantry Baking - Account</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" type="image/x-icon" href="/images/favicon-pie.png">
    <link rel="stylesheet" href="/styles/style.css">
</head>
<body class="account-body">
    <header class="sticky-top">
        <%- include('partials/navbar') %>
    </header>
    
    <section class="profile-section py-5">
        <div class="container">
            <div class="profile-card">
                <div class="row align-items-center g-4 w-100">
                    <div class="col-12 col-md-auto text-center">
                        <img class="profile-image"
                        alt="Profile picture"
                        src="<%= user.avatar %>">
                    </div>
            
                    <div class="col">
                        <div class="d-flex justify-content-between align-items-start flex-wrap">
                            <div>
                                <h1 class="mb-1">
                                    <%= user.name %>
                                </h1>
                    
                                <p class="text-muted mb-4">
                                    <%= user.email %>
                                </p>
                            </div>
                            <a href="/account/edit" class="btn edit-profile-btn"> Edit Profile
                            </a>
                        </div>
                        <div class="profile-stats">
                            <div class="stat-card">                        
                                <div class="stat-icon">
                                    ❤️
                                </div>                        
                                <h2><%= user.likedRecipes.length %></h2>                        
                                <p>Liked Recipes</p>                        
                            </div>
                        
                            <div class="stat-card">                        
                                <div class="stat-icon">
                                    🍪
                                </div>                        
                                <h2>Pantry</h2>                        
                                <p>Baker</p>                        
                            </div>                        
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Liked Recipes -->
    <section class="liked-section py-5">
        <div class="container">
            <div class="section-heading">
                <h2>❤️ Liked Recipes</h2>
                <p>Your favorite recipes all in one place.</p>
            </div>

            <div id="liked-container" class="row g-4">
                <!-- Recipe cards will go here from js -->
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script>
        window.likedRecipes = <%- JSON.stringify(user.likedRecipes) %>;
    </script>
    
    <script type="module" src="/scripts/account.js"></script>
    <script type="module" src="/scripts/recipe.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>